{
  "name": "holmgard-lore-mcp",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=browser --target=es2020 --outfile=dist/index.js --sourcemap",
    "dev": "wrangler dev dist/index.js --local",
    "deploy": "wrangler deploy --name holmgard-lore-mcp",
    "clean": "rimraf dist",
    "test": "vitest run",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.23",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.13",
    "@cloudflare/workers-types": "^4.20260608.1",
    "@eslint/js": "^9.21.0",
    "@types/node": "^20.19.42",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.18.20",
    "eslint": "^9.21.0",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
